# LLM Configuration
# Required for primary path. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here
# Optional. Default: gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash

# Optional. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_key_here
# Optional. Default: llama3-8b-8192
GROQ_MODEL=llama3-8b-8192

# Admin — required for /api/admin/* endpoints (otherwise all admin routes return 403)
ADMIN_API_KEY=choose_a_secret

# Retrieval tuning
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# API behaviour
ASK_TIMEOUT_SECONDS=30
RATE_LIMIT=20/minute
# Comma-separated origins for CORS (no credentials). Default: http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Observability — Arize Phoenix UI at http://127.0.0.1:${PHOENIX_PORT}
PHOENIX_PORT=6006
# Optional: custom Phoenix OTLP endpoint (default: http://localhost:PHOENIX_PORT/v1/traces)
PHOENIX_OTLP_ENDPOINT=
METRICS_MAXLEN=5000
# Set to 1 in tests or when Phoenix port is unavailable
SKIP_PHOENIX=0

# Evals
EVAL_DATASET_PATH=data/eval_dataset.json
MAX_EVAL_ROWS=15

# Enable live Gemini assertion in pytest (optional)
RUN_GEMINI_E2E=0
